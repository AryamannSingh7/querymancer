# Required. Google AI Studio key — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Required for /query (schema RAG) and multi-turn sessions.
# Use the Session pooler URL (port 5432), NOT the direct db.<ref>.supabase.co host —
# the direct host is IPv6-only on the free tier and unreachable from IPv4-only networks.
SUPABASE_DB_URL=

# Optional. When set, llm.generate_sql falls back to Groq Llama 3.3 70B
# whenever Gemini returns 429 (daily quota exhausted) or 5xx.
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=

# Optional model overrides — defaults shown.
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_INDEXER_MODEL=gemini-2.5-flash-lite
# GROQ_MODEL=llama-3.3-70b-versatile
# EMBED_MODEL=gemini-embedding-001
